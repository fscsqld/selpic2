{
  "installCommand": "npm install --legacy-peer-deps",
  "crons": [
    {
      "path": "/api/cron/etsy-sync",
      "schedule": "*/10 * * * *"
    }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "selpic2.vercel.app" }],
      "destination": "https://selpic.com.au/:path*",
      "permanent": true
    }
  ]
}
