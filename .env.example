# Core site URL (used for canonical links, redirects, and email tracking links)
NEXT_PUBLIC_SITE_URL=https://selpic.com.au

# Payment gateways
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Email delivery (Resend)
RESEND_API_KEY=
RESEND_FROM="SELPIC <info@selpic.com.au>"
RESEND_FROM_EMAIL=info@selpic.com.au

# Server catalog sync (sitemap + product page metadata read data/catalog/products.json)
# Use the SAME secret for both. Admin must be logged in with products:write when saving products.
# Note: On serverless hosts without persistent disk, commit or deploy this file / use external storage.
CATALOG_SYNC_SECRET=
NEXT_PUBLIC_CATALOG_SYNC_SECRET=

# Optional app settings
NODE_ENV=development
