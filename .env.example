# =============================================================================
# SELPIC — environment variables (copy to .env and fill in real values)
# Never commit .env. This file is safe to commit.
# =============================================================================

# -----------------------------------------------------------------------------
# Public site URLs (production)
# -----------------------------------------------------------------------------
# Canonical site URL: SEO (layout, sitemap, robots, JSON-LD), email tracking
# pixels/links, and safe fallbacks when window is unavailable.
NEXT_PUBLIC_SITE_URL=https://selpic.com.au

# Optional second base URL for password-reset links and server-side newsletter
# unsubscribe URL generation when window is undefined (defaults to localhost if unset).
NEXT_PUBLIC_BASE_URL=https://selpic.com.au

# Email HTML signature logo: recipients cannot load http://localhost/... images.
# If unset, logo URL = NEXT_PUBLIC_SITE_URL (or NEXT_PUBLIC_BASE_URL) + COMPANY_LOGO_URL (e.g. /logo.png).
# Optional overrides:
# NEXT_PUBLIC_EMAIL_ASSET_BASE_URL=https://www.selpic.com.au
# NEXT_PUBLIC_EMAIL_LOGO_URL=https://www.selpic.com.au/images/logo.png

# -----------------------------------------------------------------------------
# Email (Resend) — required for transactional email in production
# -----------------------------------------------------------------------------
# Order confirmation, admin/customer mail, forgot-password, newsletter (API routes).
RESEND_API_KEY=

# "Name <email@domain.com>" — must use a domain verified in Resend.
RESEND_FROM="SELPIC <info@selpic.com.au>"

# Plain email for Reply-To / legacy fallbacks.
RESEND_FROM_EMAIL=info@selpic.com.au

# -----------------------------------------------------------------------------
# Catalog sync (optional — admin product save → server JSON for SEO/sitemap)
# -----------------------------------------------------------------------------
# Set BOTH to the SAME secret. Server: CATALOG_SYNC_SECRET; browser build:
# NEXT_PUBLIC_CATALOG_SYNC_SECRET. Without these, sync is skipped.
CATALOG_SYNC_SECRET=
NEXT_PUBLIC_CATALOG_SYNC_SECRET=

# -----------------------------------------------------------------------------
# Accounting app integration (optional — main Next.js app → accounting sandbox)
# -----------------------------------------------------------------------------
# Dashboard link in admin; order import API calls this base URL.
# Defaults to http://localhost:3001 if unset (broken in production until set).
NEXT_PUBLIC_ACCOUNTING_URL=http://localhost:3001
ACCOUNTING_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# Supabase — server order ledger (Stripe-paid orders)
# -----------------------------------------------------------------------------
# Create table with supabase/migrations/001_orders.sql in the Supabase SQL editor.
NEXT_PUBLIC_SUPABASE_URL=
# Browser Supabase client + Auth session cookies (admin login, protected admin APIs).
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Required for /api/auth/register (immediate sign-in after signup) and admin user delete/cascade.
SUPABASE_SERVICE_ROLE_KEY=

# Admin: create a Supabase Auth user and set App Metadata admin=true (or role=admin / super_admin).
# Optional fallback to legacy local admin users only if Supabase sign-in fails:
# NEXT_PUBLIC_ALLOW_LEGACY_ADMIN_LOGIN=true

# Optional — server automation only: x-internal-email-secret for legacy /api/newsletter/send and /api/orders/email/send.
# INTERNAL_EMAIL_API_SECRET=

# -----------------------------------------------------------------------------
# Stripe Checkout (storefront)
# -----------------------------------------------------------------------------
# Required for Stripe Checkout: secret key server-side, publishable key in the browser.
# Success URL: /success?session_id={CHECKOUT_SESSION_ID}; cancel: /cart
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret (Dashboard → Developers → Webhooks → your endpoint). Required for /api/stripe/webhook.
STRIPE_WEBHOOK_SECRET=
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# -----------------------------------------------------------------------------
# Etsy Open API v3 (seller OAuth + order import)
# -----------------------------------------------------------------------------
# From https://www.etsy.com/developers/your-apps — Keystring = client id, Shared Secret = client secret.
# After Etsy re-approves or re-issues keys: update values only in .env.local (local) and in Vercel env
# (production). Never commit real keys — this file stays with empty placeholders only.
# Legacy alias: ETSY_API_KEY (same value as ETSY_CLIENT_ID) is still supported for older deployments.
ETSY_CLIENT_ID=
# Shared secret from Etsy — required for token exchange and for Open API `x-api-key` (KEYSTRING:SHARED_SECRET).
ETSY_CLIENT_SECRET=
# Full URL = https://YOUR_DOMAIN + path below (must match Etsy app character-for-character):
#   /api/admin/integrations/etsy/oauth/callback
ETSY_OAUTH_REDIRECT_URI=
# Optional — defaults to https://openapi.etsy.com/v3/public/oauth/token
# ETSY_OAUTH_TOKEN_URL=
# Optional — when the seller has multiple shops, pin the shop id (numeric string from Etsy).
# ETSY_SHOP_ID=

# NODE_ENV=development

# -----------------------------------------------------------------------------
# Feature flags (storefront)
# -----------------------------------------------------------------------------
# When unset or not "true", stamp checkout is hidden / blocked on Custom Design Studio.
# Set to true when stamp products go on sale.
# NEXT_PUBLIC_STAMPS_CHECKOUT_ENABLED=true

# =============================================================================
# Accounting sandbox (apps/accounting-sandbox)
# =============================================================================
# Use a separate .env inside apps/accounting-sandbox/ for that app, e.g.:
#   OPENAI_API_KEY=sk-...
# See apps/accounting-sandbox/README_ENV.md for details.
