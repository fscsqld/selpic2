                    value={contentItems.find(item => item.section === 'terms' && item.title === 'Terms and Conditions 부제목')?.content || 'Last updated: September 3, 2025'}
                    placeholder="페이지 부제목 입력"
                    type="text"
                    description="Terms and Conditions 페이지의 부제목"
                    onSave={handleQuickEditSave}
                    existingContent={contentItems.find(item => item.section === 'terms' && item.title === 'Terms and Conditions 부제목')}
                    showNotification={showNotification}
                  />

                  {/* Agreement to Terms 제목 빠른 편집 */}
                  <QuickEditCard
                    title="Agreement to Terms 제목"
                    value={contentItems.find(item => item.section === 'terms' && item.title === 'Agreement to Terms 제목')?.content || 'Agreement to Terms'}
                    placeholder="Agreement to Terms 제목 입력"
                    type="text"
                    description="Agreement to Terms 섹션의 제목"
                    onSave={handleQuickEditSave}
                    existingContent={contentItems.find(item => item.section === 'terms' && item.title === 'Agreement to Terms 제목')}
                    showNotification={showNotification}
                  />

                  {/* Agreement to Terms 내용 빠른 편집 */}
                  <QuickEditCard
                    title="Agreement to Terms 내용"
                    value={contentItems.find(item => item.section === 'terms' && item.title === 'Agreement to Terms 내용')?.content || 'By accessing and using SELPIC\'s services...'}
                    placeholder="Agreement to Terms 내용 입력"
                    type="text"
                    description="Agreement to Terms 섹션의 내용"
                    onSave={handleQuickEditSave}
                    existingContent={contentItems.find(item => item.section === 'terms' && item.title === 'Agreement to Terms 내용')}
                    showNotification={showNotification}
                  />

                  {/* Use of Service 제목 빠른 편집 */}
                  <QuickEditCard
                    title="Use of Service 제목"
                    value={contentItems.find(item => item.section === 'terms' && item.title === 'Use of Service 제목')?.content || 'Use of Service'}
                    placeholder="Use of Service 제목 입력"
                    type="text"
                    description="Use of Service 섹션의 제목"
                    onSave={handleQuickEditSave}
                    existingContent={contentItems.find(item => item.section === 'terms' && item.title === 'Use of Service 제목')}
                    showNotification={showNotification}
                  />

                  {/* Permitted Uses 제목 빠른 편집 */}
                  <QuickEditCard
                    title="Permitted Uses 제목"
                    value={contentItems.find(item => item.section === 'terms' && item.title === 'Permitted Uses 제목')?.content || 'Permitted Uses'}
                    placeholder="Permitted Uses 제목 입력"
                    type="text"
                    description="Permitted Uses 섹션의 제목"
                    onSave={handleQuickEditSave}
                    existingContent={contentItems.find(item => item.section === 'terms' && item.title === 'Permitted Uses 제목')}
                    showNotification={showNotification}
                  />

                  {/* Permitted Uses 목록 빠른 편집 */}
                  <QuickEditCard
                    title="Permitted Uses 목록"
                    value={contentItems.find(item => item.section === 'terms' && item.title === 'Permitted Uses 목록')?.content || 'Browse and purchase our products, Create custom sticker designs...'}
                    placeholder="Permitted Uses 목록 입력"
                    type="text"
                    description="Permitted Uses 섹션의 목록"
                    onSave={handleQuickEditSave}
                    existingContent={contentItems.find(item => item.section === 'terms' && item.title === 'Permitted Uses 목록')}
                    showNotification={showNotification}
                  />

                  {/* Prohibited Uses 제목 빠른 편집 */}
                  <QuickEditCard
                    title="Prohibited Uses 제목"
                    value={contentItems.find(item => item.section === 'terms' && item.title === 'Prohibited Uses 제목')?.content || 'Prohibited Uses'}
                    placeholder="Prohibited Uses 제목 입력"
                    type="text"
                    description="Prohibited Uses 섹션의 제목"
                    onSave={handleQuickEditSave}
                    existingContent={contentItems.find(item => item.section === 'terms' && item.title === 'Prohibited Uses 제목')}
                    showNotification={showNotification}
                  />

                  {/* Prohibited Uses 목록 빠른 편집 */}
                  <QuickEditCard
                    title="Prohibited Uses 목록"
                    value={contentItems.find(item => item.section === 'terms' && item.title === 'Prohibited Uses 목록')?.content || 'Violate any applicable laws or regulations...'}
                    placeholder="Prohibited Uses 목록 입력"
                    type="text"
                    description="Prohibited Uses 섹션의 목록"
                    onSave={handleQuickEditSave}
                    existingContent={contentItems.find(item => item.section === 'terms' && item.title === 'Prohibited Uses 목록')}
                    showNotification={showNotification}
                  />
                </div>
              </div>

              {/* Terms and Conditions 콘텐츠 목록 */}
              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {getContentBySection('terms').map((item) => (
                  <div 
                    key={item.id} 
                    className="bg-white rounded-lg border border-orange-200 p-4 relative"
                  >
                    <div className="flex items-center justify-between mb-3">
                      <div className="flex items-center space-x-2">
                        {item.type === 'text' && <Type className="w-4 h-4 text-orange-600" />}
                        {item.type === 'image' && <ImageIcon className="w-4 h-4 text-orange-600" />}
                        <h5 className="font-medium text-orange-900">{item.title}</h5>
                      </div>
                      <div className="flex items-center space-x-1">
                        <button
                          onClick={() => toggleContentActive(item.id)}
                          className={`p-1 rounded ${item.isActive ? 'text-orange-600' : 'text-gray-400'}`}
                        >
                          {item.isActive ? <Eye className="w-4 h-4" /> : <EyeOff className="w-4 h-4" />}
                        </button>
                        <button
                          onClick={() => openContentModal(item)}
                          className="p-1 text-blue-600 hover:bg-blue-50 rounded"
                          title="편집"
                        >
                          <Edit className="w-4 h-4" />
                        </button>
                        <button
                          onClick={() => handleContentDelete(item.id)}
                          className="p-1 text-red-600 hover:bg-red-50 rounded"
                          title="삭제"
                        >
                          <Trash2 className="w-4 h-4" />
                        </button>
                      </div>
                    </div>
                    
                    <div className="space-y-2">
                      <div className="text-sm text-gray-600">
                        <span className="font-medium">타입:</span> {item.type}
                      </div>
                      <div className="text-sm text-gray-600">
                        <span className="font-medium">내용:</span> {item.content || '내용 없음'}
                      </div>
                    </div>
                  </div>
                ))}
              </div>

              {getContentBySection('terms').length === 0 && (
                <div className="text-center py-8">
                  <div className="text-4xl mb-4">📋</div>
                  <h3 className="text-lg font-medium text-gray-900 mb-2">Terms and Conditions 콘텐츠가 없습니다</h3>
                  <p className="text-gray-600 mb-4">Terms and Conditions 페이지의 텍스트 내용을 추가해보세요.</p>
                  <button
                    onClick={() => {
                      setEditingContent(null)
                      setFormData({
                        id: '',
                        type: 'text',
                        section: 'terms',
                        title: '',
                        content: '',
                        order: 1,
                        isActive: true
                      })
                      setIsModalOpen(true)
                    }}
                    className="px-4 py-2 bg-orange-600 text-white text-sm font-medium rounded-md hover:bg-orange-700"
                  >
                    첫 번째 Terms and Conditions 콘텐츠 추가
                  </button>
                </div>
              )}
            </div>
          </div>
        )}

        {/* 상단 액션 바 - Hero 섹션이 아닐 때만 표시 */}
        {selectedSection !== 'hero' && (
        <div className="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
          <div className="flex flex-col sm:flex-row gap-4 justify-between items-start sm:items-center">
            <div className="flex gap-2">
              <button
                onClick={() => openModal()}
                className="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
              >
                <Plus className="w-4 h-4 mr-2" />
                새 콘텐츠 추가
              </button>
              
              <button
                onClick={togglePreviewMode}
                className={`inline-flex items-center px-4 py-2 border text-sm font-medium rounded-md shadow-sm focus:outline-none focus:ring-2 focus:ring-offset-2 ${
                  isPreviewMode
                    ? 'border-red-300 text-red-700 bg-red-50 hover:bg-red-100 focus:ring-red-500'
                    : 'border-gray-300 text-gray-700 bg-white hover:bg-gray-50 focus:ring-blue-500'
                }`}
              >
                {isPreviewMode ? <EyeOff className="w-4 h-4 mr-2" /> : <Eye className="w-4 h-4 mr-2" />}
                {isPreviewMode ? '미리보기 종료' : '미리보기'}
              </button>

              {isPreviewMode && (
                <button
                  onClick={applyToHomepage}
                  className="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500"
                >
                  <Save className="w-4 h-4 mr-2" />
                  홈페이지에 적용
                </button>
              )}
            </div>

            <div className="flex gap-2">
              <div className="relative">
                <Search className="absolute left-3 top-1/2 transform -translate-y-1/2 text-gray-400 w-4 h-4" />
                <input
                  type="text"
                  placeholder={`${sections.find(s => s.id === selectedSection)?.name}에서 검색...`}
                  value={searchTerm}
                  onChange={(e) => setSearchTerm(e.target.value)}
                  className="pl-10 pr-4 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                />
              </div>

              <div className="flex border border-gray-300 rounded-md">
                <button
                  onClick={() => setViewMode('grid')}
                  className={`p-2 ${viewMode === 'grid' ? 'bg-blue-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50'}`}
                >
                  <Grid className="w-4 h-4" />
                </button>
                <button
                  onClick={() => setViewMode('list')}
                  className={`p-2 ${viewMode === 'list' ? 'bg-blue-600 text-white' : 'bg-white text-gray-600 hover:bg-gray-50'}`}
                >
                  <List className="w-4 h-4" />
                </button>
              </div>
            </div>
          </div>
        </div>
        )}

        {/* 섹션 정보 및 통계 - Hero 섹션이 아닐 때만 표시 */}
        {selectedSection !== 'hero' && (
        <div className="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
          <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
            <div className="text-center p-4 bg-blue-50 rounded-lg">
              <div className="text-2xl font-bold text-blue-600">{currentSectionContent.length}</div>
              <div className="text-sm text-blue-800">전체 콘텐츠</div>
            </div>
            <div className="text-center p-4 bg-green-50 rounded-lg">
              <div className="text-2xl font-bold text-green-600">
                {currentSectionContent.filter(item => item.isActive).length}
              </div>
              <div className="text-sm text-green-800">활성 콘텐츠</div>
            </div>
            <div className="text-center p-4 bg-purple-50 rounded-lg">
              <div className="text-2xl font-bold text-purple-600">
                {currentSectionContent.filter(item => item.type === 'image').length}
              </div>
              <div className="text-sm text-purple-800">이미지</div>
            </div>
            <div className="text-center p-4 bg-orange-50 rounded-lg">
              <div className="text-2xl font-bold text-orange-600">
                {currentSectionContent.filter(item => item.type === 'video').length}
              </div>
              <div className="text-sm text-orange-800">동영상</div>
            </div>
          </div>
        </div>
        )}

        {/* 콘텐츠 목록 - Hero 섹션이 아닐 때만 표시 */}
        {selectedSection !== 'hero' && (
        <div className="bg-white rounded-lg shadow-sm border border-gray-200 overflow-hidden">
          <div className="px-6 py-4 border-b border-gray-200 bg-gray-50">
            <div className="flex items-center justify-between">
              <span className="text-sm text-gray-700">
                {sections.find(s => s.id === selectedSection)?.name} - {currentSectionContent.length}개 콘텐츠
              </span>
            </div>
          </div>

          {viewMode === 'grid' ? (
            /* 그리드 뷰 */
            <div className="p-6">
              <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                {currentSectionContent.map((item) => (
                  <div key={item.id} className="bg-gray-50 rounded-lg p-6 border border-gray-200 hover:shadow-md transition-shadow">
                    <div className="flex items-start justify-between mb-4">
                      <div className="flex items-center space-x-2">
                        {item.type === 'text' && <Type className="w-5 h-5 text-blue-600" />}
                        {item.type === 'image' && <ImageIcon className="w-5 h-5 text-green-600" />}
                        {item.type === 'video' && <Video className="w-5 h-5 text-purple-600" />}
                        <span className={`px-2 py-1 text-xs font-semibold rounded-full ${getSectionColor(item.section)}`}>
                          {item.type}
                        </span>
                      </div>
                      <div className="flex gap-2">
                        <button
                          onClick={() => openModal(item)}
                          className="text-blue-600 hover:text-blue-900 p-1"
                        >
                          <Edit className="w-4 h-4" />
                        </button>
                        <button
                          onClick={() => {
                            if (confirm('정말로 이 콘텐츠를 삭제하시겠습니까?')) {
                              deleteContent(item.id)
                              showNotification('success', '콘텐츠가 삭제되었습니다.')
                            }
                          }}
                          className="text-red-600 hover:text-red-900 p-1"
                        >
                          <Trash2 className="w-4 h-4" />
                        </button>
                      </div>
                    </div>

                    <h3 className="font-semibold text-gray-900 mb-2">{item.title}</h3>
                    <p className="text-sm text-gray-600 mb-4 line-clamp-2">{item.content}</p>

                    {item.type === 'image' && item.mediaUrl && (
                      <div className="mb-4">
                        <img
                          src={item.mediaUrl}
                          alt={item.title}
                          className="w-full h-32 object-cover rounded-lg"
                        />
                      </div>
                    )}

                    {item.type === 'video' && item.mediaUrl && (
                      <div className="mb-4 bg-gray-200 rounded-lg p-4 text-center">
                        <Video className="w-8 h-8 text-gray-600 mx-auto mb-2" />
                        <p className="text-xs text-gray-600">동영상 파일</p>
                      </div>
                    )}

                    {/* 헤더 콘텐츠 정보 표시 */}
                    {(item.type === 'link' || item.type === 'button') && (
                      <div className="mb-4 p-3 bg-blue-50 rounded-lg">
                        <div className="text-xs text-blue-800 space-y-1">
                          {item.linkUrl && (
                            <div className="flex items-center">
                              <span className="font-medium">링크:</span>
                              <span className="ml-2 text-blue-600 truncate">{item.linkUrl}</span>
                            </div>
                          )}
                          {item.type === 'button' && item.buttonStyle && (
                            <div className="flex items-center">
                              <span className="font-medium">스타일:</span>
                              <span className="ml-2 px-2 py-1 text-xs rounded bg-blue-100 text-blue-800">
                                {item.buttonStyle === 'primary' ? 'Primary' : 'Secondary'}
                              </span>
                            </div>
                          )}
                          {item.iconName && (
                            <div className="flex items-center">
                              <span className="font-medium">아이콘:</span>
                              <span className="ml-2 text-blue-600">{item.iconName}</span>
                            </div>
                          )}
                        </div>
                      </div>
                    )}

                    <div className="flex items-center justify-between">
                      <span className="text-xs text-gray-500">순서: {item.order}</span>
                      <button
                        onClick={() => toggleContentActive(item.id)}
                        className={`px-2 py-1 text-xs font-semibold rounded-full ${
                          item.isActive
                            ? 'bg-green-100 text-green-800'
                            : 'bg-gray-100 text-gray-800'
                        }`}
                      >
                        {item.isActive ? '활성' : '비활성'}
                      </button>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          ) : (
            /* 리스트 뷰 */
            <div className="overflow-x-auto">
              <table className="min-w-full divide-y divide-gray-200">
                <thead className="bg-gray-50">
                  <tr>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      콘텐츠
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      타입
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      순서
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      상태
                    </th>
                    <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">
                      작업
                    </th>
                  </tr>
                </thead>
                <tbody className="bg-white divide-y divide-gray-200">
                  {currentSectionContent.map((item) => (
                    <tr key={item.id} className="hover:bg-gray-50">
                      <td className="px-6 py-4 whitespace-nowrap">
                        <div className="flex items-center">
                          <div className="flex-shrink-0 h-10 w-10">
                            {item.type === 'image' && item.mediaUrl ? (
                              <img
                                src={item.mediaUrl}
                                alt={item.title}
                                className="h-10 w-10 rounded-lg object-cover"
                              />
                            ) : (
                              <div className="h-10 w-10 rounded-lg bg-gray-200 flex items-center justify-center">
                                {item.type === 'text' && <Type className="w-4 h-4" />}
                                {item.type === 'image' && <ImageIcon className="w-4 h-4" />}
                                {item.type === 'video' && <Video className="w-4 h-4" />}
                                {item.type === 'link' && <ArrowRight className="w-4 h-4" />}
                                {item.type === 'button' && <CheckCircle className="w-4 h-4" />}
                              </div>
                            )}
                          </div>
                          <div className="ml-4">
                            <div className="text-sm font-medium text-gray-900">{item.title}</div>
                            <div className="text-sm text-gray-500 truncate max-w-xs">{item.content}</div>
                          </div>
                        </div>
                      </td>
                      <td className="px-6 py-4 whitespace-nowrap">
                        <div className="flex items-center">
                          {item.type === 'text' && <Type className="w-4 h-4" />}
                          {item.type === 'image' && <ImageIcon className="w-4 h-4" />}
                          {item.type === 'video' && <Video className="w-4 h-4" />}
                          {item.type === 'link' && <ArrowRight className="w-4 h-4" />}
                          {item.type === 'button' && <CheckCircle className="w-4 h-4" />}
                          <span className="ml-2 text-sm text-gray-900">{item.type}</span>
                        </div>
                      </td>
                      <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-900">
                        {item.order}
                      </td>
                      <td className="px-6 py-4 whitespace-nowrap">
                        <button
                          onClick={() => toggleContentActive(item.id)}
                          className={`inline-flex px-2 py-1 text-xs font-semibold rounded-full ${
                            item.isActive
                              ? 'bg-green-100 text-green-800'
                              : 'bg-gray-100 text-gray-800'
                          }`}
                        >
                          {item.isActive ? '활성' : '비활성'}
                        </button>
                      </td>
                      <td className="px-6 py-4 whitespace-nowrap text-sm font-medium">
                        <div className="flex gap-2">
                          <button
                            onClick={() => openModal(item)}
                            className="text-blue-600 hover:text-blue-900"
                          >
                            <Edit className="w-4 h-4" />
                          </button>
                          <button
                            onClick={() => {
                              if (confirm('정말로 이 콘텐츠를 삭제하시겠습니까?')) {
                                deleteContent(item.id)
                                showNotification('success', '콘텐츠가 삭제되었습니다.')
                              }
                            }}
                            className="text-red-600 hover:text-red-900"
                          >
                            <Trash2 className="w-4 h-4" />
                          </button>
                        </div>
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          )}
        </div>
        )}

        {/* 미리보기 모드 */}
        {isPreviewMode && (
          <div className="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
            <div className="bg-white rounded-lg max-w-4xl w-full max-h-[90vh] overflow-y-auto">
              <div className="p-6 border-b border-gray-200">
                <div className="flex items-center justify-between">
                  <h3 className="text-lg font-medium text-gray-900">홈페이지 미리보기</h3>
                  <div className="flex gap-2">
                    <button
                      onClick={applyToHomepage}
                      className="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-green-600 hover:bg-green-700"
                    >
                      <Save className="w-4 h-4 mr-2" />
                      홈페이지에 적용
                    </button>
                    <button
                      onClick={togglePreviewMode}
                      className="inline-flex items-center px-4 py-2 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50"
                    >
                      <X className="w-4 h-4 mr-2" />
                      닫기
                    </button>
                  </div>
                </div>
              </div>
              
              <div className="p-6">
                <div className="space-y-8">
                  {sections.map(section => {
                    const sectionContent = previewData.filter(item => item.section === section.id && item.isActive)
                    if (sectionContent.length === 0) return null
                    
                    return (
                      <div key={section.id} className="border border-gray-200 rounded-lg p-6">
                        <h4 className="text-xl font-semibold text-gray-900 mb-4 capitalize">{section.name}</h4>
                        <div className="space-y-4">
                          {sectionContent
                            .sort((a, b) => a.order - b.order)
                            .map(item => (
                              <div key={item.id} className="p-4 bg-gray-50 rounded-lg">
                                <div className="flex items-start gap-4">
                                  {item.type === 'image' && item.mediaUrl && (
                                    <img
                                      src={item.mediaUrl}
                                      alt={item.title}
                                      className="w-24 h-24 object-cover rounded-lg"
                                    />
                                  )}
                                  {item.type === 'video' && item.mediaUrl && (
                                    <div className="w-24 h-24 bg-gray-200 rounded-lg flex items-center justify-center">
                                      <Play className="w-8 h-8 text-gray-600" />
                                    </div>
                                  )}
                                  <div className="flex-1">
                                    <h5 className="font-medium text-gray-900 mb-2">{item.title}</h5>
                                    {item.type === 'text' ? (
                                      <p className="text-gray-700">{item.content}</p>
                                    ) : (
                                      <p className="text-sm text-gray-500">{item.content}</p>
                                    )}
                                    <div className="mt-2 flex items-center gap-2">
                                      <span className={`inline-flex px-2 py-1 text-xs font-semibold rounded-full ${getSectionColor(item.section)}`}>
                                        {item.section}
                                      </span>
                                      <span className="inline-flex items-center px-2 py-1 text-xs font-semibold rounded-full bg-gray-100 text-gray-800">
                                        {item.type === 'text' && <Type className="w-3 h-3 mr-1" />}
                                        {item.type === 'image' && <ImageIcon className="w-3 h-3 mr-1" />}
                                        {item.type === 'video' && <Video className="w-3 h-3 mr-1" />}
                                        <span>{item.type}</span>
                                      </span>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            ))}
                        </div>
                      </div>
                    )
                  })}
                </div>
              </div>
            </div>
          </div>
        )}

        {/* 콘텐츠 추가/수정 모달 */}
        {isModalOpen && (
          <div className="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
            <div className="bg-white rounded-lg max-w-4xl w-full max-h-[90vh] overflow-y-auto">
              <div className="p-6 border-b border-gray-200">
                <div className="flex items-center justify-between">
                  <h3 className="text-lg font-medium text-gray-900">
                    {editingContent ? '콘텐츠 수정' : '새 콘텐츠 추가'}
                  </h3>
                  <button
                    onClick={closeModal}
                    className="text-gray-400 hover:text-gray-600"
                  >
                    <X className="w-6 h-6" />
                  </button>
                </div>
              </div>
              
              <form onSubmit={handleSubmit} className="p-6 space-y-6">
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-2">
                      섹션
                    </label>
                    <select
                      value={formData.section}
                      onChange={(e) => setFormData({ ...formData, section: e.target.value as any })}
                      className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                      required
                    >
                      {sections.map(section => (
                        <option key={section.id} value={section.id}>{section.name}</option>
                      ))}
                    </select>
                  </div>
                  
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-2">
                      콘텐츠 타입
                    </label>
                    <select
                      value={formData.type}
                      onChange={(e) => setFormData({ ...formData, type: e.target.value as any })}
                      className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                      required
                    >
                      {contentTypes.map(type => (
                        <option key={type} value={type}>{type}</option>
                      ))}
                    </select>
                  </div>
                </div>

                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-2">
                    제목
                  </label>
                  <input
                    type="text"
                    value={formData.title}
                    onChange={(e) => setFormData({ ...formData, title: e.target.value })}
                    className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                    placeholder="콘텐츠 제목을 입력하세요"
                    required
                  />
                </div>

                <div>
                  <label className="block text-sm font-medium text-gray-700 mb-2">
                    {formData.type === 'text' ? '텍스트 내용' : '설명'}
                  </label>
                  {formData.type === 'text' ? (
                    <textarea
                      value={formData.content}
                      onChange={(e) => setFormData({ ...formData, content: e.target.value })}
                      rows={4}
                      className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                      placeholder="텍스트 내용을 입력하세요"
                      required
                    />
                  ) : (
                    <input
                      type="text"
                      value={formData.content}
                      onChange={(e) => setFormData({ ...formData, content: e.target.value })}
                      className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                      placeholder="콘텐츠 설명을 입력하세요"
                      required
                    />
                  )}
                </div>

                {/* 미디어 업로드 영역 */}
                {(formData.type === 'image' || formData.type === 'video') && (
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-2">
                      {formData.type === 'image' ? '이미지' : '동영상'} 업로드
                    </label>
                    <MediaUpload
                      type={formData.type}
                      currentUrl={formData.mediaUrl}
                      onUpload={handleMediaUpload}
                      onRemove={handleMediaRemove}
                    />
                  </div>
                )}

                {/* 카테고리 전용 편집 필드들 */}
                {(formData.section === 'categories' || (formData.section === 'hero' && formData.type === 'button')) && (
                  <div className="space-y-4">
                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-2">
                        카테고리 타입
                      </label>
                      <select
                        value={formData.categoryType || ''}
                        onChange={(e) => setFormData({ ...formData, categoryType: e.target.value as any })}
                        className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                        required
                      >
                        <option value="">카테고리 타입 선택</option>
                        <option value="stickers">Stickers</option>
                        <option value="stamps">Stamps</option>
                        <option value="phone-cases">Phone Cases</option>
                        <option value="hot-goods">HOT GOODS</option>
                        <option value="others">Others</option>
                        <option value="custom-design">Custom Design</option>
                      </select>
                    </div>

                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-2">
                        이모지
                      </label>
                      <input
                        type="text"
                        value={formData.emoji || ''}
                        onChange={(e) => setFormData({ ...formData, emoji: e.target.value })}
                        className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                        placeholder="🏷️, 📮, 📱, 🔥, 🎁, 🎨"
                      />
                    </div>

                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-2">
                        링크 URL
                      </label>
                      <input
                        type="text"
                        value={formData.linkUrl || ''}
                        onChange={(e) => setFormData({ ...formData, linkUrl: e.target.value })}
                        className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                        placeholder="/products, /stamp, /phone-cases, /customize"
                        required
                      />
                    </div>

                    <div className="grid grid-cols-2 gap-4">
                      <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">
                          그라디언트 시작 색상
                        </label>
                        <input
                          type="color"
                          value={formData.gradientFrom || '#3B82F6'}
                          onChange={(e) => setFormData({ ...formData, gradientFrom: e.target.value })}
                          className="w-full h-10 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                        />
                      </div>
                      <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">
                          그라디언트 끝 색상
                        </label>
                        <input
                          type="color"
                          value={formData.gradientTo || '#8B5CF6'}
                          onChange={(e) => setFormData({ ...formData, gradientTo: e.target.value })}
                          className="w-full h-10 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                        />
                      </div>
                    </div>

                    {/* 그라디언트 미리보기 */}
                    {formData.gradientFrom && formData.gradientTo && (
                      <div>
                        <label className="block text-sm font-medium text-gray-700 mb-2">
                          그라디언트 미리보기
                        </label>
                        <div 
                          className="w-full h-16 rounded-lg border border-gray-300"
                          style={{ 
                            background: `linear-gradient(to right, ${formData.gradientFrom}, ${formData.gradientTo})` 
                          }}
                        ></div>
                      </div>
                    )}
                  </div>
                )}

                {/* 헤더 전용 편집 필드들 */}
                {(formData.type === 'link' || formData.type === 'button') && (
                  <div className="space-y-4">
                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-2">
                        링크 URL
                      </label>
                      <input
                        type="url"
                        value={formData.linkUrl || ''}
                        onChange={(e) => setFormData({ ...formData, linkUrl: e.target.value })}
                        className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                        placeholder="https://example.com"
                        required
                      />
                    </div>

                    {formData.type === 'button' && (
                      <>
                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            버튼 스타일
                          </label>
                          <select
                            value={formData.buttonStyle || 'primary'}
                            onChange={(e) => setFormData({ ...formData, buttonStyle: e.target.value as 'primary' | 'secondary' })}
                            className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                          >
                            <option value="primary">Primary (파란색)</option>
                            <option value="secondary">Secondary (회색)</option>
                          </select>
                        </div>

                        <div>
                          <label className="block text-sm font-medium text-gray-700 mb-2">
                            아이콘 이름
                          </label>
                          <input
                            type="text"
                            value={formData.iconName || ''}
                            onChange={(e) => setFormData({ ...formData, iconName: e.target.value })}
                            className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                            placeholder="ShoppingCart, User, Search 등"
                          />
                        </div>
                      </>
                    )}

                    <div>
                      <label className="block text-sm font-medium text-gray-700 mb-2">
                        링크 타겟
                      </label>
                      <select
                        value={formData.target || '_self'}
                        onChange={(e) => setFormData({ ...formData, target: e.target.value as '_self' | '_blank' })}
                        className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                      >
                        <option value="_self">현재 창에서 열기</option>
                        <option value="_blank">새 창에서 열기</option>
                      </select>
                    </div>
                  </div>
                )}

                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                  <div>
                    <label className="block text-sm font-medium text-gray-700 mb-2">
                      표시 순서
                    </label>
                    <input
                      type="number"
                      value={formData.order}
                      onChange={(e) => setFormData({ ...formData, order: parseInt(e.target.value) })}
                      className="w-full px-3 py-2 border border-gray-300 rounded-md focus:ring-blue-500 focus:border-blue-500"
                      min="1"
                      required
                    />
                  </div>
                  
                  <div className="flex items-center">
                    <input
                      type="checkbox"
                      id="isActive"
                      checked={formData.isActive}
                      onChange={(e) => setFormData({ ...formData, isActive: e.target.checked })}
                      className="rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                    />
                    <label htmlFor="isActive" className="ml-2 text-sm text-gray-700">
                      활성 상태
                    </label>
                  </div>
                </div>

                <div className="flex justify-end gap-3 pt-4">
                  <button
                    type="button"
                    onClick={closeModal}
                    className="px-4 py-2 border border-gray-300 text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
                  >
                    취소
                  </button>
                  <button
                    type="submit"
                    className="px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-blue-600 hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
                  >
                    {editingContent ? '수정' : '추가'}
                  </button>
                </div>
              </form>
            </div>
          </div>
        )}

        {/* 콘텐츠 모달 */}
        <ContentModal
          isOpen={isModalOpen}
          onClose={closeContentModal}
          onSave={handleContentSave}
          content={editingContent}
          section={selectedSection}
        />

        {/* 알림 */}
        {notification.show && (
          <div className={`fixed top-4 right-4 z-50 p-4 rounded-lg shadow-lg ${
            notification.type === 'success' ? 'bg-green-500 text-white' :
            notification.type === 'error' ? 'bg-red-500 text-white' :
            'bg-blue-500 text-white'
          }`}>
            <div className="flex items-center">
              {notification.type === 'success' && <CheckCircle className="w-5 h-5 mr-2" />}
              {notification.type === 'error' && <AlertCircle className="w-5 h-5 mr-2" />}
              <span>{notification.message}</span>
            </div>
          </div>
        )}
      </div>
    </div>
  )
}
