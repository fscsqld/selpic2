'use client'

import { useState, useEffect } from 'react'
import { Plus, Edit, Trash2, Eye, Search, X, CheckCircle, AlertCircle, Save, EyeOff, Play, Image as ImageIcon, Video, Type, Grid, List, ArrowRight, BarChart3 } from 'lucide-react'
import Header from '@/components/Header'
import MediaUpload from '@/components/MediaUpload'
import { useContentStore, ContentItem } from '@/lib/contentStore'
import { 
  sections, 
  contentTypes, 
  getSectionColor, 
  findContentByTitle, 
  QuickEditData 
} from './utils'
import QuickEditCard from './components/QuickEditCard'
import SidebarMenuManager from './components/SidebarMenuManager'
import HeroSlideManager from './components/HeroSlideManager'
import ContentModal from './components/ContentModal'

interface ContentFormData {
  id: string
  type: 'text' | 'image' | 'video' | 'link' | 'button'
  section: 'hero' | 'how-it-works' | 'cta' | 'header' | 'categories' | 'footer' | 'about' | 'privacy' | 'terms'
  title: string
  content: string
  mediaUrl?: string
  order: number
  isActive: boolean
  // 헤더 전용 필드들
  linkUrl?: string
  buttonStyle?: 'primary' | 'secondary'
  iconName?: string
  target?: '_self' | '_blank'
  // 카테고리 전용 필드들
  categoryType?: 'stickers' | 'stamps' | 'phone-cases' | 'hot-goods' | 'others' | 'custom-design'
  gradientFrom?: string
  gradientTo?: string
  emoji?: string
}

export default function AdminContentPage() {
  const { 
    _hasHydrated,
    contentItems, 
    addContent, 
    updateContent, 
    deleteContent, 
    toggleContentActive,
    getContentBySection,
    getActiveContentBySection,
    sidebarMenuItems,
    addSidebarMenuItem,
    updateSidebarMenuItem,
    deleteSidebarMenuItem,
    getActiveSidebarMenuItems,
    reorderSidebarMenuItem: storeReorderSidebarMenuItem,
    heroSlides,
    addHeroSlide,
    updateHeroSlide,
    deleteHeroSlide,
    toggleHeroSlideActive,
    reorderHeroSlide,
    getActiveHeroSlides
  } = useContentStore()

  // 컴포넌트 마운트 시 기존 헤더 콘텐츠 로드
  useEffect(() => {
    // 클라이언트 사이드에서만 실행
    if (typeof window !== 'undefined') {
    const headerContent = getActiveContentBySection('header')
    
    // 회사명 로드
    const companyNameItem = headerContent.find(item => item.title === '회사명')
    if (companyNameItem) {
      setCompanyName(companyNameItem.content)
    }
    
    // 홈 링크 로드
    const homeLinkItem = headerContent.find(item => item.title === '홈 링크')
    if (homeLinkItem && homeLinkItem.linkUrl) {
      setHomeLinkUrl(homeLinkItem.linkUrl)
    }
    
    // 제품 링크 로드
    const productsLinkItem = headerContent.find(item => item.title === '제품 링크')
    if (productsLinkItem && productsLinkItem.linkUrl) {
      setProductsLinkUrl(productsLinkItem.linkUrl)
      }
      
      // 로고 로드
      const logoItem = headerContent.find(item => item.title === '로고')
      if (logoItem && logoItem.mediaUrl) {
        setLogoUrl(logoItem.mediaUrl)
      }
      
      // 테마 색상 로드
      const themeItem = headerContent.find(item => item.title === '테마 색상')
      if (themeItem && themeItem.content) {
        setThemeColor(themeItem.content)
      }
    }
  }, [getActiveContentBySection])
  
  const [isModalOpen, setIsModalOpen] = useState(false)
  const [editingContent, setEditingContent] = useState<ContentItem | null>(null)
  const [searchTerm, setSearchTerm] = useState('')
  const [selectedSection, setSelectedSection] = useState<'hero' | 'how-it-works' | 'cta' | 'header' | 'footer' | 'about' | 'privacy' | 'terms'>('header')
  const [isPreviewMode, setIsPreviewMode] = useState(false)
  const [previewData, setPreviewData] = useState<ContentItem[]>([])
  const [viewMode, setViewMode] = useState<'grid' | 'list'>('grid')
  const [notification, setNotification] = useState<{
    type: 'success' | 'error' | 'info'
    message: string
    show: boolean
  }>({ type: 'info', message: '', show: false })

  // 빠른 편집을 위한 상태 변수들
  const [companyName, setCompanyName] = useState('')
  const [homeLinkUrl, setHomeLinkUrl] = useState('/')
  const [productsLinkUrl, setProductsLinkUrl] = useState('/products')
  const [logoUrl, setLogoUrl] = useState('')
  const [themeColor, setThemeColor] = useState('#3B82F6')
  const [formData, setFormData] = useState<ContentFormData>({
    id: '',
    type: 'text',
    section: 'header',
    title: '',
    content: '',
    mediaUrl: '',
    order: 0,
    isActive: true
  })



  // 현재 선택된 섹션의 콘텐츠만 필터링
  const currentSectionContent = contentItems
    .filter(item => item.section === selectedSection)
    .filter(item => {
      const matchesSearch = item.title.toLowerCase().includes(searchTerm.toLowerCase()) ||
                           item.content.toLowerCase().includes(searchTerm.toLowerCase())
      return matchesSearch
    })
    .sort((a, b) => a.order - b.order)

  // 알림 표시 함수
  const showNotification = (type: 'success' | 'error' | 'info', message: string) => {
    setNotification({ type, message, show: true })
    setTimeout(() => {
      setNotification({ type: 'info', message: '', show: false })
    }, 3000)
  }

  // 모달 열기/닫기 함수
  const openModal = (content?: ContentItem) => {
    if (content) {
      setEditingContent(content)
      setFormData(content)
    } else {
      setEditingContent(null)
      setFormData({
        id: '',
        type: 'text',
        section: selectedSection,
        title: '',
        content: '',
        mediaUrl: '',
        order: currentSectionContent.length + 1,
        isActive: true
      })
    }
    setIsModalOpen(true)
  }

  const closeModal = () => {
    setIsModalOpen(false)
    setEditingContent(null)
    setFormData({
      id: '',
      type: 'text',
              section: 'header',
      title: '',
      content: '',
      mediaUrl: '',
      order: 0,
      isActive: true
    })
  }

  // 폼 제출 처리
  const handleSubmit = (e: React.FormEvent) => {
    e.preventDefault()
    
    if (editingContent) {
      updateContent(editingContent.id, formData)
      showNotification('success', '콘텐츠가 성공적으로 수정되었습니다.')
    } else {
      addContent(formData)
      showNotification('success', '새 콘텐츠가 성공적으로 추가되었습니다.')
    }
    
    closeModal()
  }

  // 미디어 업로드 처리
  const handleMediaUpload = (file: File, url: string) => {
    setFormData(prev => ({
      ...prev,
      mediaUrl: url
    }))
  }

  // 미디어 제거 처리
  const handleMediaRemove = () => {
    setFormData(prev => ({
      ...prev,
      mediaUrl: ''
    }))
  }

  // 미리보기 모드 토글
  const togglePreviewMode = () => {
    if (isPreviewMode) {
      setIsPreviewMode(false)
      setPreviewData([])
    } else {
      setPreviewData([...contentItems])
      setIsPreviewMode(true)
    }
  }

  // 홈페이지에 적용
  const applyToHomepage = () => {
    showNotification('success', '변경사항이 홈페이지에 성공적으로 적용되었습니다!')
    setIsPreviewMode(false)
    setPreviewData([])
  }



  // 섹션 변경 시 검색어 초기화
  const handleSectionChange = (section: 'hero' | 'how-it-works' | 'cta' | 'header' | 'footer') => {
    setSelectedSection(section)
    setSearchTerm('')
  }

  // 콘텐츠 모달 핸들러들
  const openContentModal = (content?: ContentItem) => {
    setEditingContent(content || null)
    setIsModalOpen(true)
  }

  const closeContentModal = () => {
    setEditingContent(null)
    setIsModalOpen(false)
  }

  const handleContentSave = (data: ContentItem) => {
    if (editingContent) {
      updateContent(data.id, data)
    } else {
      addContent(data)
    }
    closeContentModal()
  }

  const handleContentDelete = (id: string) => {
    if (confirm('정말로 이 콘텐츠를 삭제하시겠습니까?')) {
      deleteContent(id)
    }
  }

  // 통합된 빠른 편집 저장 함수
  const handleQuickEditSave = (data: QuickEditData) => {
    console.log('빠른 편집 저장:', data)
    console.log('현재 콘텐츠 아이템들:', contentItems.length)
    
    // 섹션별로 기존 콘텐츠 찾기
    let existingContent = findContentByTitle(contentItems, 'header', data.title)
    let targetSection = 'header'
    
    if (!existingContent) {
      existingContent = findContentByTitle(contentItems, 'footer', data.title)
      targetSection = 'footer'
    }
    
    if (!existingContent) {
      existingContent = findContentByTitle(contentItems, 'how-it-works', data.title)
      targetSection = 'how-it-works'
    }
    
    if (!existingContent) {
      existingContent = findContentByTitle(contentItems, 'about', data.title)
      targetSection = 'about'
    }
    
    if (!existingContent) {
      existingContent = findContentByTitle(contentItems, 'privacy', data.title)
      targetSection = 'privacy'
    }
    
    if (!existingContent) {
      existingContent = findContentByTitle(contentItems, 'terms', data.title)
      targetSection = 'terms'
    }
    
    console.log('찾은 기존 콘텐츠:', existingContent)
    console.log('대상 섹션:', targetSection)
    
    if (existingContent) {
      // 기존 콘텐츠 업데이트
      console.log('기존 콘텐츠 업데이트:', existingContent.id)
      const updatedContent = {
        ...existingContent,
        content: data.content,
        linkUrl: data.linkUrl,
        updatedAt: new Date()
      }
      console.log('업데이트할 콘텐츠:', updatedContent)
      
      updateContent(existingContent.id, updatedContent)
      
      // 성공 메시지 표시
      alert(`콘텐츠가 성공적으로 저장되었습니다!\n제목: ${data.title}\n내용: ${data.content}`)
      
      // 업데이트 후 상태 확인
      setTimeout(() => {
        const updatedItem = contentItems.find(item => item.id === existingContent.id)
        console.log('업데이트 후 아이템:', updatedItem)
      }, 100)
    } else {
      // 새 콘텐츠 추가
      console.log('새 콘텐츠 추가')
      addContent({
        type: data.type,
        section: targetSection as any,
        title: data.title,
        content: data.content,
        linkUrl: data.linkUrl,
        order: data.order,
        isActive: true
      })
      
      // 성공 메시지 표시
      alert('새 콘텐츠가 성공적으로 추가되었습니다!')
    }
  }

  // 빠른 편집 상태 업데이트 함수들
  const handleLogoUpload = (file: File, url: string) => {
    setLogoUrl(url)
    // 로고 URL을 콘텐츠에 저장
    const existingLogo = contentItems.find(item => item.section === 'header' && item.title === '로고')
    if (existingLogo) {
      updateContent(existingLogo.id, { ...existingLogo, mediaUrl: url })
    } else {
      addContent({
        type: 'image',
        section: 'header',
        title: '로고',
        content: '회사 로고',
        mediaUrl: url,
      order: 1,
        isActive: true
      })
    }
    showNotification('success', '로고가 성공적으로 업로드되었습니다.')
  }



  // 하이드레이션이 완료될 때까지 로딩 표시
  if (!_hasHydrated) {
    return (
      <div className="min-h-screen bg-gray-50 flex items-center justify-center">
        <div className="text-center">
          <div className="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600 mx-auto mb-4"></div>
          <p className="text-gray-600">로딩 중...</p>
        </div>
      </div>
    )
  }

  return (
    <div className="min-h-screen bg-gray-50">
      {/* 헤더 */}
      <div className="bg-white/90 backdrop-blur supports-[backdrop-filter]:bg-white/70 shadow-sm border-b">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div className="flex items-center justify-between h-16">
            <div className="flex items-center space-x-4">
              <button
                onClick={() => window.location.href = '/admin/dashboard'}
                className="flex items-center text-gray-600 hover:text-gray-900"
              >
                <ArrowRight className="w-5 h-5 mr-2 rotate-180" />
                Dashboard
              </button>
            </div>
            <h1 className="text-2xl md:text-3xl font-bold tracking-tight text-gray-900">콘텐츠 관리</h1>
            <div className="flex items-center space-x-4">
              <span className="text-sm text-gray-500">
                홈페이지 콘텐츠 관리
              </span>
              <button
                onClick={() => window.location.reload()}
                className="px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors duration-200 text-sm"
              >
                새로고침
              </button>
              <button
                onClick={() => window.open('/privacy', '_blank')}
                className="px-4 py-2 bg-green-600 text-white rounded-lg hover:bg-green-700 transition-colors duration-200 text-sm"
              >
                Privacy Policy 확인
              </button>
            </div>
          </div>
        </div>
      </div>
      
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        {/* 페이지 설명 */}
        <div className="mb-8">
          <p className="text-gray-600">홈페이지의 각 섹션별로 텍스트, 이미지, 동영상을 체계적으로 관리할 수 있습니다.</p>
        </div>



        {/* 섹션 탭 네비게이션 */}
        <div className="bg-white rounded-lg shadow-sm border border-gray-200 p-6 mb-6">
          <div className="flex flex-wrap gap-2">
            {sections.map((section) => (
              <button
                key={section.id}
                onClick={() => handleSectionChange(section.id as any)}
                className={`px-6 py-3 rounded-lg font-medium transition-all duration-200 ${
                  selectedSection === section.id
                    ? 'bg-blue-600 text-white shadow-lg'
                    : 'bg-gray-100 text-gray-700 hover:bg-gray-200'
                }`}
              >
                <div className="text-center">
                  <div className="font-semibold">{section.name}</div>
                  <div className="text-xs opacity-80 mt-1">{section.description}</div>
                </div>
              </button>
            ))}
          </div>
        </div>

        {/* 헤더 섹션 빠른 편집 */}
        {selectedSection === 'header' && (
          <div className="bg-gradient-to-r from-indigo-50 to-purple-50 rounded-lg shadow-sm border border-indigo-200 p-6 mb-6">
            <div className="flex items-center justify-between mb-4">
              <div>
                <h3 className="text-lg font-semibold text-indigo-900">🚀 빠른 편집</h3>
                <p className="text-sm text-indigo-700">자주 사용하는 헤더 요소를 빠르게 수정할 수 있습니다.</p>
              </div>
              <div className="flex items-center space-x-2">
                <span className="px-3 py-1 bg-indigo-100 text-indigo-800 text-xs font-medium rounded-full">
                  Header 섹션
                </span>
              </div>
            </div>
            
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
              {/* 회사명 빠른 편집 */}
              <QuickEditCard
                title="회사명"
                    value={companyName || contentItems.find(item => item.section === 'header' && item.title === '회사명')?.content || ''}
                    placeholder="회사명 입력"
                type="text"
                description="홈페이지 헤더에 즉시 반영됩니다."
                onSave={handleQuickEditSave}
                existingContent={contentItems.find(item => item.section === 'header' && item.title === '회사명')}
                showNotification={showNotification}
              />

              {/* 홈 링크 빠른 편집 */}
              <QuickEditCard
                title="홈 링크"
                value={homeLinkUrl || contentItems.find(item => item.section === 'header' && item.title === '홈 링크')?.linkUrl || '/'}
                placeholder="홈 링크 URL"
                type="url"
                description="네비게이션 홈 버튼 링크를 변경합니다."
                onSave={handleQuickEditSave}
                existingContent={contentItems.find(item => item.section === 'header' && item.title === '홈 링크')}
                showNotification={showNotification}
              />

              {/* 제품 링크 빠른 편집 */}
              <QuickEditCard
                title="제품 링크"
                value={productsLinkUrl || contentItems.find(item => item.section === 'header' && item.title === '제품 링크')?.linkUrl || '/products'}
                placeholder="제품 링크 URL"
                type="url"
                description="네비게이션 제품 버튼 링크를 변경합니다."
                onSave={handleQuickEditSave}
                existingContent={contentItems.find(item => item.section === 'header' && item.title === '제품 링크')}
                showNotification={showNotification}
              />

              {/* 로고 업로드 */}
              <div className="bg-white rounded-lg border border-gray-200 p-4">
                <div className="flex items-center justify-between mb-3">
                  <h4 className="text-sm font-medium text-gray-900">로고 업로드</h4>
                  <ImageIcon className="w-4 h-4 text-gray-400" />
                </div>
                <div className="space-y-3">
                  {logoUrl ? (
                    <div className="relative">
                      <img
                        src={logoUrl}
                        alt="로고"
                        className="w-full h-20 object-contain rounded-lg border border-gray-200"
                  />
                  <button
                        onClick={() => {
                          setLogoUrl('')
                          showNotification('success', '로고가 제거되었습니다.')
                        }}
                        className="absolute top-1 right-1 p-1 bg-red-500 text-white rounded-full hover:bg-red-600"
                      >
                        <X className="w-3 h-3" />
                  </button>
                </div>
                  ) : (
                    <div className="border-2 border-dashed border-gray-300 rounded-lg p-4 text-center">
                      <ImageIcon className="w-8 h-8 text-gray-400 mx-auto mb-2" />
                      <p className="text-xs text-gray-500">로고 이미지를 업로드하세요</p>
                    </div>
                  )}
                  <MediaUpload
                    type="image"
                    currentUrl={logoUrl}
                    onUpload={handleLogoUpload}
                    onRemove={() => setLogoUrl('')}
                  />
                </div>
              </div>
              </div>

            {/* 테마 색상 설정 */}
            <div className="mt-6 bg-white rounded-lg border border-gray-200 p-4">
              <div className="flex items-center justify-between mb-3">
                <h4 className="text-sm font-medium text-gray-900">테마 색상</h4>
                <div className="w-6 h-6 rounded-full border-2 border-gray-300" style={{ backgroundColor: themeColor }}></div>
                </div>
              <div className="flex items-center space-x-4">
                  <input
                  type="color"
                  value={themeColor}
                  onChange={(e) => setThemeColor(e.target.value)}
                  className="w-12 h-8 border border-gray-300 rounded cursor-pointer"
                />
                <input
                  type="text"
                  value={themeColor}
                  onChange={(e) => setThemeColor(e.target.value)}
                  className="flex-1 px-3 py-2 border border-gray-300 rounded-md text-sm"
                  placeholder="#3B82F6"
                  />
                  <button
                  onClick={() => {
                    const existingTheme = contentItems.find(item => item.section === 'header' && item.title === '테마 색상')
                    if (existingTheme) {
                      updateContent(existingTheme.id, { ...existingTheme, content: themeColor })
                    } else {
                      addContent({
                        type: 'text',
                        section: 'header',
                        title: '테마 색상',
                        content: themeColor,
                        order: 10,
                        isActive: true
                      })
                    }
                    showNotification('success', '테마 색상이 저장되었습니다.')
                  }}
                  className="px-3 py-2 bg-blue-600 text-white text-sm rounded-md hover:bg-blue-700"
                  >
                    저장
                  </button>
                </div>
              </div>

            {/* 사이드바 메뉴 관리 */}
            <div className="mt-8">
              <SidebarMenuManager
                sidebarMenuItems={sidebarMenuItems}
                onAddMenuItem={addSidebarMenuItem}
                onUpdateMenuItem={updateSidebarMenuItem}
                onDeleteMenuItem={deleteSidebarMenuItem}
                onReorderMenuItem={storeReorderSidebarMenuItem}
                showNotification={showNotification}
              />
                 </div>
          </div>
        )}

        {/* Hero 섹션 관리 */}
        {selectedSection === 'hero' && (
          <div className="space-y-6">
            {/* Hero 슬라이드 관리 */}
            <HeroSlideManager
              heroSlides={heroSlides}
              onAddSlide={addHeroSlide}
              onUpdateSlide={updateHeroSlide}
              onDeleteSlide={deleteHeroSlide}
              onToggleSlideActive={toggleHeroSlideActive}
              onReorderSlide={reorderHeroSlide}
              showNotification={showNotification}
            />

            {/* 카테고리 섹션 관리 */}
            <div className="bg-gradient-to-r from-pink-50 to-rose-50 rounded-lg p-6 border border-pink-200">
              <div className="flex items-center justify-between mb-4">
                <div>
                  <h4 className="text-lg font-semibold text-pink-900">🛍️ 카테고리 섹션 관리</h4>
                  <p className="text-sm text-pink-700">홈페이지의 상품 카테고리 섹션을 관리할 수 있습니다.</p>
                </div>
                <button
                  onClick={() => {
                    setEditingContent(null)
                    setFormData({
                      id: '',
                      type: 'button',
                      section: 'categories',
                      title: '',
                      content: '',
                      order: getContentBySection('categories').length + 1,
                      isActive: true,
                      categoryType: 'stickers',
                      gradientFrom: '#3B82F6',
                      gradientTo: '#8B5CF6',
                      emoji: '📦'
