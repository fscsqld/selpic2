                          onClick={() => toggleContentActive(item.id)}
                          className={`p-1 rounded ${item.isActive ? 'text-green-600' : 'text-gray-400'}`}
                        >
                          {item.isActive ? <Eye className="w-4 h-4" /> : <EyeOff className="w-4 h-4" />}
                        </button>
                        <button
                          onClick={() => openContentModal(item)}
                          className="p-1 text-blue-600 hover:bg-blue-50 rounded"
                          title="편집"
                        >
                          <Edit className="w-4 h-4" />
                        </button>
                        <button
                          onClick={() => handleContentDelete(item.id)}
                          className="p-1 text-red-600 hover:bg-red-50 rounded"
                          title="삭제"
                        >
                          <Trash2 className="w-4 h-4" />
                        </button>
                       </div>
                    </div>
                    
                    <div className="space-y-2">
                      <div className="text-sm text-gray-600">
                        <span className="font-medium">타입:</span> {item.type}
                      </div>
                      <div className="text-sm text-gray-600">
                        <span className="font-medium">내용:</span> {item.content || '내용 없음'}
                      </div>
                      {item.mediaUrl && (
                        <div className="text-sm text-gray-600">
                          <span className="font-medium">미디어:</span> 
                          {item.type === 'image' ? (
                            <img src={item.mediaUrl} alt={item.title} className="w-16 h-16 object-cover rounded mt-1" />
                          ) : (
                            <span className="ml-1">동영상 파일</span>
                          )}
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>

