{
  "name": "selpic-sticker-shop",
  "version": "0.1.2",
  "private": true,
  "description": "SELPIC storefront — bump when forcing fresh Vercel/CDN behavior (2026-04-05 react keys)",
  "scripts": {
    "predev": "npm run clean",
    "dev": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --webpack --port 3005 --hostname 0.0.0.0",
    "predev:webpack": "npm run clean",
    "dev:turbo": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --port 3005 --hostname 0.0.0.0",
    "dev:webpack": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --webpack --port 3005 --hostname 0.0.0.0",
    "predev:all": "npm run clean",
    "dev:all": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --webpack --port 3005 --hostname 0.0.0.0",
    "dev:3001": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --webpack --port 3005 --hostname 0.0.0.0",
    "dev:home": "node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --webpack --port 3005 --hostname 0.0.0.0",
    "dev:accounting": "cd apps/accounting-sandbox && npm run dev",
    "build": "next build --webpack",
    "start": "next start --port 3005",
    "start:3001": "next start --port 3005",
    "lint": "next lint",
    "clean": "node scripts/clean.mjs",
    "redev": "npm run clean && node --max-old-space-size=8192 node_modules/next/dist/bin/next dev --webpack --port 3005 --hostname 0.0.0.0",
    "reset": "npm run clean && npm install && npm run dev",
    "type-check": "tsc --noEmit",
    "test": "echo \"No tests specified\" && exit 0",
    "verify:ledger": "node scripts/verify-order-ledger.mjs",
    "grant:admin": "node scripts/grant-supabase-admin.mjs",
    "generate-report": "node scripts/generate-report.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^1.7.17",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "autoprefixer": "^10.0.1",
    "baseline-browser-mapping": "^2.10.20",
    "browser-image-compression": "^2.0.2",
    "caniuse-lite": "^1.0.30001788",
    "clsx": "^2.0.0",
    "framer-motion": "^10.18.0",
    "html2pdf.js": "^0.12.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.292.0",
    "next": "^16.2.2",
    "pdf-parse": "^2.4.5",
    "postcss": "^8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.47.0",
    "react-image-gallery": "^2.1.1",
    "react-is": "^19.2.4",
    "recharts": "^3.7.0",
    "resend": "^6.9.4",
    "server-only": "^0.0.1",
    "stripe": "^21.0.1",
    "swiper": "^11.0.0",
    "tailwindcss": "^3.3.0",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "dotenv": "^17.4.0",
    "eslint": "^8",
    "eslint-config-next": "^15.5.0",
    "typescript": "^5.9.3"
  }
}
