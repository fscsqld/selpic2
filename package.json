{
  "name": "selpic-sticker-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "dev:all": "next dev --port 3000 --hostname 0.0.0.0",
    "dev:3001": "next dev --port 3001 --hostname 0.0.0.0",
    "dev:home": "next dev --port 3001 --hostname 0.0.0.0",
    "dev:accounting": "cd apps/accounting-sandbox && npm run dev",
    "build": "next build",
    "start": "next start --port 3000",
    "start:3001": "next start --port 3001",
    "lint": "next lint",
    "clean": "if exist .next rmdir /s /q .next && if exist node_modules\\.cache rmdir /s /q node_modules\\.cache",
    "reset": "npm run clean && npm install && npm run dev",
    "type-check": "tsc --noEmit",
    "test": "echo \"No tests specified\" && exit 0",
    "verify:ledger": "node scripts/verify-order-ledger.mjs",
    "grant:admin": "node scripts/grant-supabase-admin.mjs",
    "generate-report": "node scripts/generate-report.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^1.7.17",
    "@stripe/stripe-js": "^9.0.1",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "autoprefixer": "^10.0.1",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.0.0",
    "framer-motion": "^10.18.0",
    "html2pdf.js": "^0.12.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.292.0",
    "next": "^16.2.2",
    "pdf-parse": "^2.4.5",
    "postcss": "^8",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.47.0",
    "react-image-gallery": "^2.1.1",
    "recharts": "^3.7.0",
    "resend": "^6.9.4",
    "server-only": "^0.0.1",
    "stripe": "^21.0.1",
    "swiper": "^11.0.0",
    "tailwindcss": "^3.3.0",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^17.4.0",
    "eslint": "^8",
    "eslint-config-next": "^15.5.0",
    "typescript": "^5"
  }
}
