{
  "name": "selpic-sticker-shop",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000 --hostname 0.0.0.0",
    "dev:3001": "next dev --port 3001 --hostname 0.0.0.0",
    "dev:accounting": "cd apps/accounting-sandbox && npm run dev",
    "build": "next build",
    "start": "next start --port 3000",
    "start:3001": "next start --port 3001",
    "lint": "next lint",
    "clean": "if exist .next rmdir /s /q .next && if exist node_modules\\.cache rmdir /s /q node_modules\\.cache",
    "reset": "npm run clean && npm install && npm run dev",
    "type-check": "tsc --noEmit",
    "test": "echo \"No tests specified\" && exit 0",
    "generate-report": "node scripts/generate-report.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@headlessui/react": "^1.7.17",
    "autoprefixer": "^10.0.1",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.0.0",
    "framer-motion": "^10.18.0",
    "html2pdf.js": "^0.12.1",
    "lucide-react": "^0.292.0",
    "next": "^15.5.0",
    "postcss": "^8",
    "react": "^18",
    "react-dom": "^18",
    "react-hook-form": "^7.47.0",
    "react-image-gallery": "^1.4.0",
    "react-markdown": "^10.1.0",
    "recharts": "^3.6.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.6.0",
    "swiper": "^11.2.10",
    "tailwindcss": "^3.3.0",
    "zustand": "^4.4.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "eslint": "^8",
    "eslint-config-next": "^15.5.0",
    "typescript": "^5"
  }
}
